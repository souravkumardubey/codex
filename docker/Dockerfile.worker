FROM node:20-alpine AS builder

WORKDIR /app

RUN apk add --no-cache docker-cli

COPY package.json package-lock.json tsconfig.json turbo.json ./
COPY apps/worker apps/worker
COPY libs libs
COPY prisma prisma

RUN npm ci
RUN npx prisma generate
RUN npm run build --filter=@codex/worker

FROM node:20-alpine AS runner

WORKDIR /app

RUN apk add --no-cache docker-cli
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 worker

COPY --from=builder /app/apps/worker/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/prisma ./prisma

RUN rm -rf node_modules/@codex && \
    for lib in shared logger database queue sandbox; do \
      mkdir -p node_modules/@codex/$lib && \
      printf '{"main":"../../dist/libs/%s/src/index.js"}' "$lib" > node_modules/@codex/$lib/package.json; \
    done

USER worker

ENV NODE_ENV=production

CMD ["node", "dist/apps/worker/src/main"]
