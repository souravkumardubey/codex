# Database
DATABASE_URL=postgresql://codex:codex123@localhost:5432/codex?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Application
NODE_ENV=development
PORT=4000
WORKER_PORT=4001
WS_PORT=4002

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=codex-network
EXECUTION_TIMEOUT=30000
MAX_MEMORY=512m
MAX_CPU=1

# BullMQ
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=1000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000,https://codex.vercel.app

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3001

# ── Deployment ──────────────────────────────────────────────────
# Frontend URLs (set these in Vercel project settings)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4002

# VPS deployment
DOMAIN=api.codex.dev
DEPLOY_HOST=root@api.codex.dev
